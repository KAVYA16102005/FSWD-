const express = require("express");
const app = express();

app.use(express.json());

let students = [
 {id:1,name:"Rahul",course:"CSE"},
 {id:2,name:"Anita",course:"IT"}
];

app.get("/students",(req,res)=>{
 res.json(students);
});

app.listen(3000,()=>{
 console.log("Server running on port 3000");
});
